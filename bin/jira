function detectLocale() {
  const env = process.env.LANG || process.env.LC_ALL || process.env.LC_MESSAGES || '';
  return env.toLowerCase().startsWith('zh') ? 'zh' : 'en';
}

let _lang = null;

function getLang() {
  if (_lang) return _lang;
  const config = loadConfig();
  const cfgLang = config?.lang;
  if (cfgLang === 'zh' || cfgLang === 'en') {
    _lang = cfgLang;
  } else {
    _lang = detectLocale();
  }
  return _lang;
}

function t(key, ...args) {
  const lang = getLang();
  let msg = (messages[lang] && messages[lang][key]) || messages.en[key] || key;
  args.forEach((val, i) => {
    msg = msg.replace(`{${i}}`, val);
  });
  return msg;
}

// ── Config Management ────────────────────────────────────

const CONFIG_DIR = path.join(require('os').homedir(), '.jira-cli');
const CONFIG_FILE = path.join(CONFIG_DIR, 'config.json');

function loadConfig() {
  try {
    return JSON.parse(fs.readFileSync(CONFIG_FILE, 'utf8'));
  } catch {
    return null;
  }
}

function saveConfig(config) {
  if (!fs.existsSync(CONFIG_DIR)) fs.mkdirSync(CONFIG_DIR, { recursive: true });
  fs.writeFileSync(CONFIG_FILE, JSON.stringify(config, null, 2));
  fs.chmodSync(CONFIG_FILE, 0o600);
}

function requireConfig() {
  const config = loadConfig();
  if (!config) {
    console.error(t('config.not_configured'));
    process.exit(1);
  }
  return config;
}

// ── HTTP Request ─────────────────────────────────────────

function request(config, method, apiPath, body) {
  return new Promise((resolve, reject) => {
    const url = new URL(apiPath, config.host);
    const isHttps = url.protocol === 'https:';
    const mod = isHttps ? https : http;

    const headers = {
      'Content-Type': 'application/json',
      Accept: 'application/json',
    };

    // Authentication
    if (config.cookie) {
      // Cookie auth (SSO login)
      headers['Cookie'] = config.cookie;
    } else if (config.username && config.password) {
      // Jira Server: Basic auth with username:password
      headers['Authorization'] =
        'Basic ' + Buffer.from(`${config.username}:${config.password}`).toString('base64');
    } else if (config.email && config.token) {
      // Jira Cloud: Basic auth with email:api-token
      headers['Authorization'] =
        'Basic ' + Buffer.from(`${config.email}:${config.token}`).toString('base64');
    } else if (config.token) {
      // Jira Server/DC: Bearer token
      headers['Authorization'] = `Bearer ${config.token}`;
    }

    const options = {
      hostname: url.hostname,
      port: url.port || (isHttps ? 443 : 80),
      path: url.pathname + url.search,
      method,
      headers,
      rejectUnauthorized: config.insecure ? false : true,
    };

    const req = mod.request(options, (res) => {
      let data = '';
      res.on('data', (chunk) => (data += chunk));
      res.on('end', () => {
        if (res.statusCode >= 400) {
          let msg = `HTTP ${res.statusCode}`;
          try {
            const err = JSON.parse(data);
            msg += ': ' + (err.errorMessages?.join(', ') || err.message || data);
          } catch {
            msg += ': ' + data.slice(0, 200);
          }
          reject(new Error(msg));
        } else {
          try {
            resolve(data ? JSON.parse(data) : null);
          } catch {
            resolve(data);
          }
        }
      });
    });

    req.on('error', reject);
    if (body) req.write(JSON.stringify(body));
    req.end();
  });
}

function jiraApi(config, method, path, body) {
  // Support Jira instances with path prefix (e.g. https://jira.company.com/jira)
  const url = new URL(config.host);
  const prefix = url.pathname.replace(/\/+$/, '');
  return request(config, method, `${prefix}/rest/api/2${path}`, body);
}

// ── Terminal Utilities ───────────────────────────────────

const C = {
  reset: '\x1b[0m',
  bold: '\x1b[1m',
  dim: '\x1b[2m',
  red: '\x1b[31m',
  green: '\x1b[32m',
  yellow: '\x1b[33m',
  blue: '\x1b[34m',
  cyan: '\x1b[36m',
  white: '\x1b[37m',
  gray: '\x1b[90m',
};

function c(color, text) {
  return `${C[color]}${text}${C.reset}`;
}

function prompt(question) {
  const rl = readline.createInterface({ input: process.stdin, output: process.stdout });
  return new Promise((resolve) => {
    rl.question(question, (answer) => {
      rl.close();
      resolve(answer.trim());
    });
  });
}

function truncate(str, len) {
  if (!str) return '';
  str = str.replace(/\n/g, ' ');
  return str.length > len ? str.slice(0, len - 1) + '...' : str;
}

function formatDate(dateStr) {
  if (!dateStr) return '-';
  return dateStr.replace(/T.*/, '');
}

// Convert Jira wiki/ADF to plain text
function simplifyDescription(desc) {
  if (!desc) return t('no_description');
  if (typeof desc === 'string') {
    // Wiki markup - simple conversion
    return desc
      .replace(/\{code[^}]*\}/g, '```')
      .replace(/\{noformat\}/g, '```')
      .replace(/h[1-6]\.\s*/g, '## ')
      .replace(/\*([^*]+)\*/g, '$1')
      .replace(/_([^_]+)_/g, '$1')
      .replace(/\[([^|]+)\|([^\]]+)\]/g, '$1 ($2)')
      .replace(/\[([^\]]+)\]/g, '$1');
  }
  // ADF (Atlassian Document Format) - recursive text extraction
  if (typeof desc === 'object') {
    return extractAdfText(desc);
  }
  return String(desc);
}

function extractAdfText(node) {
  if (!node) return '';
  if (typeof node === 'string') return node;
  if (node.type === 'text') return node.text || '';
  if (node.type === 'hardBreak') return '\n';
  if (node.type === 'codeBlock') {
    const code = (node.content || []).map(extractAdfText).join('');
    return '\n```\n' + code + '\n```\n';
  }
  if (node.type === 'heading') {
    const level = node.attrs?.level || 2;
    const text = (node.content || []).map(extractAdfText).join('');
    return '#'.repeat(level) + ' ' + text + '\n';
  }
  if (node.type === 'bulletList' || node.type === 'orderedList') {
    return (node.content || [])
      .map((item, i) => {
        const prefix = node.type === 'orderedList' ? `${i + 1}. ` : '- ';
        return prefix + (item.content || []).map(extractAdfText).join('');
      })
      .join('\n') + '\n';
  }
  if (node.content) {
    return node.content.map(extractAdfText).join('') + (node.type === 'paragraph' ? '\n' : '');
  }
  return '';
}

// ── Status Color Mapping ─────────────────────────────────

function statusColor(status) {
  const s = (status || '').toLowerCase();
  if (['done', 'closed', 'resolved'].some((k) => s.includes(k))) return 'green';
  if (['progress', 'review'].some((k) => s.includes(k))) return 'blue';
  if (['todo', 'open', 'backlog'].some((k) => s.includes(k))) return 'yellow';
  return 'white';
}

function priorityIcon(priority) {
  const p = (priority || '').toLowerCase();
  if (p.includes('highest') || p.includes('blocker')) return c('red', '!!!');
  if (p.includes('high') || p.includes('critical')) return c('red', '!! ');
  if (p.includes('medium')) return c('yellow', '!  ');
  if (p.includes('low')) return c('green', '.  ');
  return c('gray', '   ');
}

// ── Commands ─────────────────────────────────────────────

async function cmdConfig() {
  const existing = loadConfig();
  console.log(c('bold', '\n' + t('config.title') + '\n'));

  if (existing) {
    console.log(t('config.current', existing.host, existing.username || existing.email || 'token auth'));
    const update = await prompt(t('config.reconfigure'));
    if (update.toLowerCase() !== 'y') return;
  }

  const host = await prompt(t('config.url_prompt'));
  if (!host) return console.error(t('config.url_empty'));

  console.log(c('dim', '\n' + t('config.auth_method')));
  console.log(c('dim', t('config.auth_cookie')));
  console.log(c('dim', t('config.auth_basic')));
  console.log(c('dim', t('config.auth_cloud')));
  console.log(c('dim', t('config.auth_pat') + '\n'));

  const authType = await prompt(t('config.auth_choose')) || '1';

  let config;
  if (authType === '1') {
    const insecure = (await prompt(t('config.skip_ssl'))).toLowerCase() === 'y';
    config = { host: host.replace(/\/+$/, ''), insecure };

    // Try auto-read Chrome cookie first; fall back to manual paste if it fails.
    const domain = new URL(config.host).hostname;
    console.log(c('dim', '\n' + t('ac.reading', domain)));
    console.log(c('dim', t('ac.keychain_hint') + '\n'));

    let autoOk = false;
    try {
      const { getCookiesForDomain } = require('./chrome-cookie');
      const { cookies, cookieString } = getCookiesForDomain(domain);
      if (cookies.length > 0) {
        console.log(c('dim', t('ac.found_cookies', cookies.length)));
        config.cookie = cookieString;
        autoOk = true;
      } else {
        console.log(c('yellow', t('ac.no_cookies', domain)));
        console.log(c('dim', t('ac.ensure_login')));
      }
    } catch (err) {
      console.log(c('yellow', t('config.auto_failed_fallback', err.message)));
    }

    if (!autoOk) {
      console.log(c('dim', '\n' + t('config.cookie_howto')));
      console.log(c('dim', t('config.cookie_step1')));
      console.log(c('dim', t('config.cookie_step2')));
      console.log(c('dim', t('config.cookie_step3')));
      console.log(c('dim', t('config.cookie_step4') + '\n'));
      const cookie = await prompt(t('config.cookie_prompt'));
      if (!cookie) return console.error(t('config.cookie_empty'));
      config.cookie = cookie;
    }
  } else if (authType === '2') {
    const username = await prompt(t('config.username_prompt'));
    if (!username) return console.error(t('config.username_empty'));
    const password = await prompt(t('config.password_prompt'));
    if (!password) return console.error(t('config.password_empty'));
    const insecure = (await prompt(t('config.skip_ssl'))).toLowerCase() === 'y';
    config = { host: host.replace(/\/+$/, ''), username, password, insecure };
  } else if (authType === '3') {
    const email = await prompt(t('config.email_prompt'));
    if (!email) return console.error(t('config.email_empty'));
    const token = await prompt(t('config.token_prompt'));
    if (!token) return console.error(t('config.token_empty'));
    const insecure = (await prompt(t('config.skip_ssl'))).toLowerCase() === 'y';
    config = { host: host.replace(/\/+$/, ''), email, token, insecure };
  } else {
    const token = await prompt(t('config.pat_prompt'));
    if (!token) return console.error(t('config.token_empty'));
    const insecure = (await prompt(t('config.skip_ssl'))).toLowerCase() === 'y';
    config = { host: host.replace(/\/+$/, ''), token, insecure };
  }

  // Language selection
  const langChoice = await prompt(t('config.lang_prompt'));
  if (langChoice === 'zh' || langChoice === 'en') {
    config.lang = langChoice;
    _lang = langChoice;
  }

  // Verify connection
  process.stdout.write('\n' + t('config.verifying'));
  try {
    const me = await jiraApi(config, 'GET', '/myself');
    console.log(c('green', t('config.success', me.displayName)));
    saveConfig(config);
    console.log(c('dim', t('config.saved', CONFIG_FILE) + '\n'));
  } catch (err) {
    console.log(c('red', t('config.failed', err.message)));
  }
}

async function cmdCookie() {
  const config = loadConfig();
  if (!config) {
    console.error(t('cookie.run_config_first'));
    process.exit(1);
  }
  console.log(c('bold', '\n' + t('cookie.title') + '\n'));
  console.log(c('dim', t('cookie.hint') + '\n'));
  const cookie = await prompt(t('config.cookie_prompt'));
  if (!cookie) return console.error(t('config.cookie_empty'));
  config.cookie = cookie;

  process.stdout.write('\n' + t('config.verifying'));
  try {
    const me = await jiraApi(config, 'GET', '/myself');
    console.log(c('green', t('config.success', me.displayName)));
    saveConfig(config);
    console.log(c('dim', t('cookie.updated') + '\n'));
  } catch (err) {
    console.log(c('red', t('config.failed', err.message)));
  }
}

async function cmdAutoCookie() {
  let config = loadConfig();

  // First-time setup
  if (!config) {
    console.log(c('bold', '\n' + t('ac.title') + '\n'));
    const host = await prompt(t('config.url_prompt'));
    if (!host) return console.error(t('config.url_empty'));
    const insecure = (await prompt(t('config.skip_ssl'))).toLowerCase() === 'y';
    config = { host: host.replace(/\/+$/, ''), insecure };
  }

  const domain = new URL(config.host).hostname;
  console.log(c('dim', '\n' + t('ac.reading', domain)));
  console.log(c('dim', t('ac.keychain_hint') + '\n'));

  try {
    const { getCookiesForDomain } = require('./chrome-cookie');
    const { cookies, cookieString } = getCookiesForDomain(domain);

    if (cookies.length === 0) {
      console.log(c('red', t('ac.no_cookies', domain)));
      console.log(c('dim', t('ac.ensure_login')));
      return;
    }

    console.log(c('dim', t('ac.found_cookies', cookies.length)));
    config.cookie = cookieString;

    // Verify
    process.stdout.write(t('config.verifying'));
    const me = await jiraApi(config, 'GET', '/myself');
    console.log(c('green', t('config.success', me.displayName)));
    saveConfig(config);
    console.log(c('dim', t('config.saved', CONFIG_FILE) + '\n'));
  } catch (err) {
    console.log(c('red', t('config.failed', err.message)));
    console.log(c('dim', '\n' + t('ac.chrome_hint')));
    console.log(c('dim', t('ac.fallback_hint')));
  }
}

async function cmdView(issueKey) {
  if (!issueKey) {
    console.error(t('view.usage'));
    process.exit(1);
  }
  const config = requireConfig();
  const issue = await jiraApi(
    config,
    'GET',
    `/issue/${issueKey}?fields=summary,status,priority,assignee,reporter,created,updated,description,comment,issuetype,labels,components,fixVersions`,
  );

  const f = issue.fields;
  console.log();
  console.log(c('bold', `${issue.key}`) + c('dim', ` ${f.issuetype?.name || ''}`));
  console.log(c('bold', f.summary));
  console.log();
  console.log(
    `${t('view.status')}: ${c(statusColor(f.status?.name), f.status?.name || '-')}    ` +
      `${t('view.priority')}: ${f.priority?.name || '-'}    ` +
      `${t('view.type')}: ${f.issuetype?.name || '-'}`,
  );
  console.log(
    `${t('view.assignee')}: ${f.assignee?.displayName || t('view.unassigned')}    ` +
      `${t('view.reporter')}: ${f.reporter?.displayName || '-'}`,
  );
  console.log(
    `${t('view.created')}: ${formatDate(f.created)}    ` + `${t('view.updated')}: ${formatDate(f.updated)}`,
  );
  if (f.labels?.length) console.log(`${t('view.labels')}: ${f.labels.join(', ')}`);
  if (f.components?.length)
    console.log(`${t('view.components')}: ${f.components.map((c) => c.name).join(', ')}`);
  if (f.fixVersions?.length)
    console.log(`${t('view.fix_versions')}: ${f.fixVersions.map((v) => v.name).join(', ')}`);

  console.log(c('dim', `\n─── ${t('view.description')} ────────────────────────────────`));
  console.log(simplifyDescription(f.description));

  // Show recent comments
  const comments = f.comment?.comments || [];
  if (comments.length > 0) {
    console.log(c('dim', `\n─── ${t('view.recent_comments')} ────────────────────────────`));
    const recent = comments.slice(-5);
    for (const cm of recent) {
      console.log(
        `\n${c('cyan', cm.author?.displayName || '?')} ${c('dim', formatDate(cm.created))}`,
      );
      console.log(simplifyDescription(cm.body));
    }
  }

  console.log(c('dim', `\n${t('view.link')}: ${config.host}/browse/${issue.key}\n`));
}

async function cmdList(jqlOrPreset) {
  const config = requireConfig();
  let jql;

  // Preset queries
  const presets = {
    mine: 'assignee = currentUser() AND resolution = Unresolved ORDER BY priority DESC, updated DESC',
    'my-bugs':
      'assignee = currentUser() AND issuetype = Bug AND resolution = Unresolved ORDER BY priority DESC',
    recent:
      'assignee = currentUser() AND updated >= -7d ORDER BY updated DESC',
    todo: 'assignee = currentUser() AND status in ("To Do", "Open", "Backlog") ORDER BY priority DESC',
  };

  if (!jqlOrPreset) {
    jql = presets.mine;
    console.log(c('dim', t('list.default_hint') + '\n'));
  } else if (presets[jqlOrPreset]) {
    jql = presets[jqlOrPreset];
    console.log(c('dim', t('list.preset_hint', jqlOrPreset) + '\n'));
  } else {
    jql = jqlOrPreset;
  }

  const result = await jiraApi(
    config,
    'GET',
    `/search?jql=${encodeURIComponent(jql)}&maxResults=30&fields=summary,status,priority,assignee,updated,issuetype`,
  );

  if (result.total === 0) {
    console.log(c('yellow', t('list.no_match')));
    return;
  }

  console.log(c('dim', t('list.total', result.total, result.issues.length) + '\n'));

  // Table output
  const keyWidth = Math.max(...result.issues.map((i) => i.key.length), 5);
  const cols = process.stdout.columns || 120;
  const summaryWidth = cols - keyWidth - 30;

  for (const issue of result.issues) {
    const f = issue.fields;
    const status = f.status?.name || '';
    console.log(
      `${priorityIcon(f.priority?.name)} ` +
        `${c('cyan', issue.key.padEnd(keyWidth))} ` +
        `${c(statusColor(status), status.padEnd(12).slice(0, 12))} ` +
        `${truncate(f.summary, summaryWidth)}`,
    );
  }
  console.log();
}

async function cmdSearch(keyword) {
  if (!keyword) {
    console.error(t('search.usage'));
    process.exit(1);
  }
  const jql = `text ~ "${keyword}" ORDER BY updated DESC`;
  await cmdList(jql);
}

async function cmdComment(issueKey, ...messageParts) {
  if (!issueKey) {
    console.error(t('comment.usage'));
    process.exit(1);
  }
  const config = requireConfig();
  let message = messageParts.join(' ');
  if (!message) {
    message = await prompt(t('comment.prompt'));
  }
  if (!message) return;

  await jiraApi(config, 'POST', `/issue/${issueKey}/comment`, { body: message });
  console.log(c('green', t('comment.added', issueKey)));
}

async function cmdAssign(issueKey, ...nameParts) {
  if (!issueKey) {
    console.error(t('assign.usage'));
    process.exit(1);
  }
  const config = requireConfig();
  let nameQuery = nameParts.join(' ');
  if (!nameQuery) {
    nameQuery = await prompt(t('assign.prompt'));
  }
  if (!nameQuery) return;

  // Search users
  const users = await jiraApi(config, 'GET', `/user/search?username=${encodeURIComponent(nameQuery)}&maxResults=10`);

  if (!users || users.length === 0) {
    console.error(c('red', t('assign.not_found', nameQuery)));
    return;
  }

  let targetUser;
  if (users.length === 1) {
    targetUser = users[0];
  } else {
    // Multiple matches
    console.log(c('bold', '\n' + t('assign.found_users', users.length) + '\n'));
    users.forEach((u, i) => {
      console.log(`  ${c('cyan', String(i + 1))}. ${u.displayName} ${c('dim', `(${u.name})`)} ${c('dim', u.emailAddress || '')}`);
    });
    const choice = await prompt('\n' + t('assign.select'));
    const idx = parseInt(choice) - 1;
    if (idx < 0 || idx >= users.length) {
      console.error(t('assign.invalid'));
      return;
    }
    targetUser = users[idx];
  }

  // Assign
  await request(config, 'PUT', `${new URL(config.host).pathname.replace(/\/+$/, '')}/rest/api/2/issue/${issueKey}/assignee`, { name: targetUser.name });
  console.log(c('green', t('assign.done', issueKey, targetUser.displayName, targetUser.name)));
}

async function cmdTransition(issueKey, targetStatus) {
  if (!issueKey) {
    console.error(t('transition.usage'));
    process.exit(1);
  }
  const config = requireConfig();

  // Get available transitions
  const { transitions } = await jiraApi(config, 'GET', `/issue/${issueKey}/transitions`);

  if (!targetStatus) {
    console.log(c('bold', '\n' + t('transition.available', issueKey) + '\n'));
    transitions.forEach((tr, i) => {
      console.log(`  ${c('cyan', String(i + 1))}. ${tr.name} ${c('dim', `(${tr.to.name})`)}`);
    });
    const choice = await prompt('\n' + t('transition.select'));
    const idx = parseInt(choice) - 1;
    if (idx >= 0 && idx < transitions.length) {
      targetStatus = transitions[idx].name;
    } else {
      targetStatus = choice;
    }
  }

  const transition = transitions.find(
    (tr) =>
      tr.name.toLowerCase() === targetStatus.toLowerCase() ||
      tr.to.name.toLowerCase() === targetStatus.toLowerCase(),
  );

  if (!transition) {
    console.error(
      c('red', t('transition.not_found', targetStatus, transitions.map((tr) => tr.name).join(', '))),
    );
    process.exit(1);
  }

  await jiraApi(config, 'POST', `/issue/${issueKey}/transitions`, {
    transition: { id: transition.id },
  });
  console.log(c('green', t('transition.done', issueKey, transition.to.name)));
}

async function cmdBranch(issueKey) {
  if (!issueKey) {
    console.error(t('branch.usage'));
    process.exit(1);
  }
  const config = requireConfig();
  const issue = await jiraApi(config, 'GET', `/issue/${issueKey}?fields=summary,issuetype`);
  const f = issue.fields;

  // Generate branch name: fix/PROJ-123-summary-text
  const type = (f.issuetype?.name || '').toLowerCase();
  const prefix = type === 'bug' ? 'fix' : type === 'story' ? 'feat' : type === 'task' ? 'chore' : 'feat';
  const slug = f.summary
    .toLowerCase()
    .replace(/[^a-z0-9\u4e00-\u9fa5]+/g, '-')
    .replace(/^-|-$/g, '')
    .slice(0, 40);
  const branchName = `${prefix}/${issue.key}-${slug}`;

  console.log('\n' + t('branch.suggested', c('cyan', branchName)));
  const confirm = await prompt(t('branch.confirm'));
  if (confirm.toLowerCase() === 'n') return;

  const { execSync } = require('child_process');
  try {
    execSync(`git checkout -b "${branchName}"`, { stdio: 'inherit' });
    console.log(c('green', '\n' + t('branch.created', branchName)));
  } catch {
    console.error(c('red', t('branch.failed')));
  }
}

async function cmdFixlog(issueKey, ...msgParts) {
  if (!issueKey) {
    console.error(t('fixlog.usage'));
    process.exit(1);
  }
  const config = requireConfig();
  let message = msgParts.join(' ');
  if (!message) {
    message = await prompt(t('fixlog.prompt'));
  }
  if (!message) return;

  const comment = `[Fix Log]\n${message}\n\n_-- via jira-cli_`;
  await jiraApi(config, 'POST', `/issue/${issueKey}/comment`, { body: comment });
  console.log(c('green', t('fixlog.added', issueKey)));

  // Ask about status transition
  const move = await prompt(t('fixlog.move_prompt'));
  if (move) {
    await cmdTransition(issueKey, move);
  }
}

// ── Init (copy skill files) ─────────────────────────────

function cmdInit() {
  const skills = ['jira-workflow'];
  const srcBase = path.join(__dirname, '..', '.claude', 'skills');
  const destBase = path.join(process.cwd(), '.claude', 'skills');

  // Check if already exists
  const allExist = skills.every(s => fs.existsSync(path.join(destBase, s, 'SKILL.md')));
  if (allExist) {
    console.log(c('yellow', t('init.already')));
    return;
  }

  console.log(t('init.copying'));
  try {
    for (const skill of skills) {
      const src = path.join(srcBase, skill, 'SKILL.md');
      const dest = path.join(destBase, skill, 'SKILL.md');
      if (!fs.existsSync(src)) continue;
      fs.mkdirSync(path.join(destBase, skill), { recursive: true });
      fs.copyFileSync(src, dest);
    }
    console.log(c('green', t('init.done')));
  } catch (err) {
    console.error(c('red', t('init.failed', err.message)));
    process.exit(1);
  }
}

// ── Help ─────────────────────────────────────────────────

function cmdHelp() {
  console.log(`
${c('bold', t('help.title'))} - ${t('help.subtitle')}

${c('bold', t('help.setup'))}
${t('help.init')}
${t('help.config')}
${t('help.ac')}
${t('help.cookie')}

${c('bold', t('help.view_title'))}
${t('help.view')}
${t('help.open')}

${c('bold', t('help.search_title'))}
${t('help.list')}
${t('help.list_mine')}
${t('help.list_bugs')}
${t('help.list_recent')}
${t('help.list_todo')}
${t('help.list_jql')}
${t('help.search')}

${c('bold', t('help.actions_title'))}
${t('help.assign')}
${t('help.comment')}
${t('help.move')}
${t('help.branch')}
${t('help.fixlog')}

${c('bold', t('help.presets_title'))}
${t('help.preset_mine')}
${t('help.preset_bugs')}
${t('help.preset_recent')}
${t('help.preset_todo')}

${c('bold', t('help.examples_title'))}
  jira config
  jira list
  jira list my-bugs
  jira view PROJ-123
  jira search "login failed"
  jira branch PROJ-123
  jira comment PROJ-123 "Fixed, pending verification"
  jira move PROJ-123 Done
  jira fixlog PROJ-123 "Fixed null pointer exception"
`);
}

// ── Main Entry ───────────────────────────────────────────

async function main() {
  const [, , cmd, ...args] = process.argv;

  try {
    switch (cmd) {
      case 'init':
        return cmdInit();
      case 'config':
        return await cmdConfig();
      case 'cookie':
        return await cmdCookie();
      case 'auto-cookie':
      case 'ac':
        return await cmdAutoCookie();
      case 'view':
      case 'show':
        return await cmdView(args[0]);
      case 'list':
      case 'ls':
        return await cmdList(args.join(' ') || undefined);
      case 'search':
      case 'find':
        return await cmdSearch(args.join(' '));
      case 'assign':
        return await cmdAssign(args[0], ...args.slice(1));
      case 'comment':
        return await cmdComment(args[0], ...args.slice(1));
      case 'move':
      case 'transition':
        return await cmdTransition(args[0], args.slice(1).join(' ') || undefined);
      case 'branch':
        return await cmdBranch(args[0]);
      case 'fixlog':
        return await cmdFixlog(args[0], ...args.slice(1));
      case 'open': {
        const config = requireConfig();
        if (!args[0]) {
          console.error(t('open.usage'));
          process.exit(1);
        }
        const { execSync } = require('child_process');
        const openCmd = process.platform === 'darwin' ? 'open' : process.platform === 'win32' ? 'start' : 'xdg-open';
        execSync(`${openCmd} "${config.host}/browse/${args[0]}"`, { stdio: 'inherit' });
        return;
      }
      case 'help':
      case '--help':
      case '-h':
      case undefined:
        return cmdHelp();
      default:
        // If looks like PROJ-123, treat as view
        if (/^[A-Z]+-\d+$/i.test(cmd)) {
          return await cmdView(cmd);
        }
        console.error(t('error.unknown_cmd', cmd));
        process.exit(1);
    }
  } catch (err) {
    console.error(c('red', `Error: ${err.message}`));
    process.exit(1);
  }
}

main();
